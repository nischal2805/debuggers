# ── LLM Provider ────────────────────────────────────────────────────────────
# nova uses Amazon Nova Lite via AWS Bedrock Converse API (confirmed working)
# MiniMax was broken: outputs entirely in reasoning chain, no text block
LLM_PROVIDER=nova

# ── AWS Bedrock credentials ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# ── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:5174

# ── Code execution ───────────────────────────────────────────────────────────
PISTON_URL=
JUDGE0_URL=https://ce.judge0.com
JUDGE0_API_KEY=

# ── Demo / SQLite ─────────────────────────────────────────────────────────────
DEMO_MODE=true
SQLITE_PATH=neuraldsa_demo.db
